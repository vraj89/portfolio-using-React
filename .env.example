# EmailJS Configuration
# Get these from your EmailJS account (https://www.emailjs.com/)

# Your EmailJS Public Key
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (e.g., service_abc123xyz)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (e.g., template_abc123xyz)
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Note: Rename this file to .env.local and fill in the actual values
# See EMAIL_SETUP.md for detailed instructions
